# ── Redis ──────────────────────────────────────────
JOBSCRAPER_REDIS_URL=redis://localhost:6379/0
JOBSCRAPER_REDIS_MAX_CONNECTIONS=50

# ── Scraping ──────────────────────────────────────
JOBSCRAPER_JOB_TTL_SECONDS=86400
JOBSCRAPER_MAX_CONCURRENT_SCRAPERS=50
JOBSCRAPER_SCRAPE_INTERVAL_HOURS=6
JOBSCRAPER_REQUEST_TIMEOUT_SECONDS=30
JOBSCRAPER_MAX_RETRIES=3
JOBSCRAPER_RETRY_BASE_DELAY=1.0
JOBSCRAPER_RATE_LIMIT_PER_SECOND=5.0

# ── API ───────────────────────────────────────────
JOBSCRAPER_API_HOST=0.0.0.0
JOBSCRAPER_API_PORT=8000
JOBSCRAPER_API_DEFAULT_PAGE_SIZE=25
JOBSCRAPER_API_MAX_PAGE_SIZE=100

# ── USAJOBS API (optional) ───────────────────────
JOBSCRAPER_USAJOBS_API_KEY=
JOBSCRAPER_USAJOBS_USER_AGENT=

# ── Logging ───────────────────────────────────────
JOBSCRAPER_LOG_LEVEL=INFO

# ── Supabase / Postgres Database ──────────────────
JOBSCRAPER_SUPABASE_DB_HOST=
JOBSCRAPER_SUPABASE_DB_PORT=5432
JOBSCRAPER_SUPABASE_DB_USER=postgres
JOBSCRAPER_SUPABASE_DB_PASSWORD=
JOBSCRAPER_SUPABASE_DB_NAME=postgres
JOBSCRAPER_SUPABASE_URL=
JOBSCRAPER_SUPABASE_SERVICE_KEY=

